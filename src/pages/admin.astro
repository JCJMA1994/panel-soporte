---
// src/pages/admin.astro
import Layout from "@/layouts/Layout.astro";
import { createSupabaseServerClient } from "@/lib/supabase/server";
import AdminSidebar from "@/components/AdminSidebar";
import AdminHeader from "@/components/AdminHeader";
import AdminTicketManager, {
    type AdminTicket,
} from "@/components/AdminTicketManager";

let errorMessage = "";
let allTickets: any = [];
let techniciansList: any = [];
let profile: any = null;
let user: any = null;

try {
// Lógica de servidor para protección de ruta
const supabase = createSupabaseServerClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();
user = userData?.user;

if (!user) {
    console.log("[ADMIN.ASTRO] No user found in session, redirecting to /login");
} else {
    const { data: profileData, error: profileError } = await supabase
        .from("profiles")
        .select("role, full_name")
        .eq("id", user.id)
        .single();
    
    profile = profileData;

    console.log(`[ADMIN.ASTRO] User ID: ${user.id}, Profile:`, profile, `Error:`, profileError);

    if (!profile || profile.role !== "administrador") {
        console.log("[ADMIN.ASTRO] Profile is not admin, redirecting to /dashboard");
    } else {
        // Obtener datos de tickets
        const { data: ticketsData } = await supabase
            .from("tickets")
            .select(
                `
                id, created_at, title, status, priority, technician_id, solution,
                profiles:client_id ( full_name, email ),
                technician:technician_id ( full_name, email )
            `,
            )
            .order("created_at", { ascending: false });

        allTickets = ticketsData || [];

        // Obtener lista de técnicos disponibles (solo administradores)
        const { data: techniciansData } = await supabase
            .from("profiles")
            .select("id, full_name, email")
            .eq("role", "administrador")
            .order("full_name", { ascending: true });
        
        techniciansList = techniciansData || [];
    }
}
} catch (error: any) {
    console.error("FATAL ERROR IN ADMIN.ASTRO:", error);
    errorMessage = error?.message || String(error);
}

if (!user && !errorMessage) {
    return Astro.redirect("/login");
}
if (user && profile?.role !== "administrador" && !errorMessage) {
    return Astro.redirect("/dashboard");
}

let ticketsToRender = (allTickets as AdminTicket[]) || [];
const technicians = techniciansList || [];

---

{errorMessage ? (
    <Layout title="Error en Servidor">
        <div class="flex items-center justify-center min-h-screen bg-slate-50">
            <div class="bg-white p-8 rounded-xl border border-red-200 shadow-md max-w-2xl w-full text-center">
                <div class="w-16 h-16 bg-red-100 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-bold">!</div>
                <h1 class="text-2xl font-bold text-slate-800 mb-2">Error Crítico del Servidor</h1>
                <p class="text-slate-500 mb-6">Ha ocurrido un error inesperado al procesar la solicitud en Vercel.</p>
                <div class="bg-red-50 text-red-800 p-4 rounded-lg text-left overflow-auto font-mono text-sm">
                    {errorMessage}
                </div>
            </div>
        </div>
    </Layout>
) : (
<Layout title="Admin Console | SupportOS">
    <div class="flex min-h-screen bg-[#F8FAFC]">
        <!-- Sidebar -->
        <AdminSidebar user={user} profile={profile} client:load />

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- Header -->
            <AdminHeader totalTickets={allTickets?.length || 0} client:load />

            <!-- Content -->
            <main class="flex-1 overflow-y-auto p-8">
                <div class="max-w-[1600px] mx-auto space-y-8">
                    <AdminTicketManager
                        initialTickets={ticketsToRender}
                        technicians={technicians}
                        client:load
                    />
                </div>
            </main>
        </div>
    </div>
</Layout>
)}

<style is:global>
    /* Optimizaciones de fuente para el look premium */
    body {
        font-family:
            "Inter",
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            Roboto,
            sans-serif;
        -webkit-font-smoothing: antialiased;
    }
</style>
